# Shared
ENVIRONMENT=local
LOG_LEVEL=INFO
NATS_URL=nats://nats:4222

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5434
POSTGRES_DB=forza
POSTGRES_USER=forza
POSTGRES_PASSWORD=forza

# Ingest
INGEST_BIND_HOST=0.0.0.0
INGEST_BIND_PORT=5300
INGEST_NATS_ENABLED=true
INGEST_SESSION_ID=local-session

# Stream
STREAM_WS_PORT=8101
STREAM_NATS_ENABLED=true

# Session
SESSION_DATABASE_URL=sqlite:////tmp/forza_sessions.db
SESSION_NATS_ENABLED=true

# Analytics
ANALYTICS_NATS_ENABLED=true
SESSION_SERVICE_BASE_URL=http://session-service:8000

# Device Gateway
DEVICE_GATEWAY_ENABLED=true
DEVICE_NATS_ENABLED=true
DEVICE_ADAPTERS=simulated
DEVICE_UDP_HOST=127.0.0.1
DEVICE_UDP_PORT=49000

# Frontend
VITE_API_BASE_URL=http://localhost:8102
VITE_ANALYTICS_API_BASE_URL=http://localhost:8103
VITE_STREAM_WS_URL=ws://localhost:8101/ws/telemetry
